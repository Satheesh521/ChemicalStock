# Environment Variables Template for ChemicalStock App
# Copy this file to .env and replace placeholder values with your actual credentials
# DO NOT commit .env file to version control

# Supabase Configuration (MANDATORY)
# Get these from your Supabase project settings > API
EXPO_PUBLIC_SUPABASE_URL=your-supabase-url-here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App Configuration
EXPO_PUBLIC_APP_NAME=ChemicalStock
EXPO_PUBLIC_DEBUG=true

# Development Settings
EXPO_PUBLIC_ENABLE_LOGGING=true

# Firebase Auth (Optional - if using Firebase for login)
# Get these from your Firebase project settings
# EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Optional: Google Sign-In
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Optional: Notification Settings
# EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
